{
  "name": "medicine-adherence-assistant",
  "version": "0.1.0",
  "description": "IoT medication reminder app with an Expo mobile assistant and Vercel-deployed React landing page.",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "preview:laptop": "set BROWSER=none&& expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "expo": "~55.0.0",
    "expo-audio": "~1.0.7",
    "expo-camera": "~17.0.9",
    "expo-file-system": "~19.0.11",
    "expo-notifications": "~0.32.12",
    "expo-speech": "~14.0.7",
    "react": "19.1.1",
    "react-dom": "19.2.0",
    "react-native": "0.82.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^55.0.17",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  }
}
