{
  "expo": {
    "name": "Medicine Adherence Assistant",
    "slug": "medicine-adherence-assistant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F6EF"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Medicine Adherence Assistant to use the camera for pill verification."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Medicine Adherence Assistant to use the microphone for medication confirmation."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#163020",
          "defaultChannel": "medication-reminders"
        }
      ]
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "The app uses the camera to verify pill intake.",
        "NSMicrophoneUsageDescription": "The app uses the microphone to capture medication confirmation.",
        "NSUserNotificationsUsageDescription": "The app sends reminder and caregiver alert notifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F6EF"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
