# Copy this file to `.env` for local development.
# Do not commit real API keys to `.env.example`.

EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Official Gemini variable used by the mobile app client.
EXPO_PUBLIC_GEMINI_API_KEY=your-official-gemini-api-key

# Reserved server-side Gemini variable for backend/web integrations.
GEMINI_API_KEY=your-official-gemini-api-key
